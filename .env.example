# Environment variables - copy to .env on server or set in hosting panel
# For InfinityFree: Set these in File Manager > Create/Edit .env file

APP_URL=https://www.mistydev.id.vn
APP_ENV=production
FB_PIXEL_ID=

# Database Configuration
# For InfinityFree: Get from Control Panel > Databases > MySQL Database
# ⚠️  DO NOT use "localhost" - use the host provided by InfinityFree (e.g., if0_XXXXX.db.infinityfree.com)
DB_HOST=if0_XXXXX.db.infinityfree.com
DB_PORT=3306
DB_DATABASE=if0_XXXXX_mistysoft
DB_USERNAME=if0_XXXXX_mistyuser
DB_PASSWORD=your_password_here

MAIL_FROM=noreply@mistysoft.vn
MAIL_FROM_NAME=MistySoft
MAIL_TO=contact@mistysoft.vn
MAIL_USE_SMTP=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

MESSENGER_URL=https://m.me/mistysoft
